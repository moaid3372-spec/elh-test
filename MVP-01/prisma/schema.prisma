generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum Role {
  STUDENT
  PARENT
  TEACHER
  ADMIN
}



model User {

  id String @id @default(uuid())

  name String

  username String @unique

  password String

  email String? @unique

  phone String?

  role Role @default(STUDENT)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt


  student Student?

  parent Parent?

}



model Student {
learningPathId String?

learningPath LearningPath?
  id String @id @default(uuid())


  userId String @unique

  user User @relation(
    fields:[userId],
    references:[id]
  )


  grade String


  points Int @default(0)

  level Int @default(1)


  progress Progress[]


  achievements Achievement[]


}



model Parent {

  id String @id @default(uuid())


  userId String @unique

  user User @relation(
    fields:[userId],
    references:[id]
  )


  children Student[]

}



model Grade {

 id String @id @default(uuid())


 name String


 units Unit[]

}



model Unit {

 id String @id @default(uuid())


 title String


 gradeId String

 grade Grade @relation(
 fields:[gradeId],
 references:[id]
 )


 lessons Lesson[]

}



model Lesson {

 id String @id @default(uuid())


 title String


 description String


 unitId String


 unit Unit @relation(
 fields:[unitId],
 references:[id]
 )


 activities Activity[]

}



model Activity {

 id String @id @default(uuid())


 title String


 type String


 lessonId String


 lesson Lesson @relation(
 fields:[lessonId],
 references:[id]
 )


}



model Progress {

 id String @id @default(uuid())


 studentId String


 student Student @relation(
 fields:[studentId],
 references:[id]
 )


 lessonId String


 completed Boolean @default(false)


 score Int?



 createdAt DateTime @default(now())

}



model Achievement {

 id String @id @default(uuid())


 title String


 description String


 studentId String


 student Student @relation(
 fields:[studentId],
 references:[id]
 )


 createdAt DateTime @default(now())
model PlacementTest {

  id String @id @default(uuid())

  title String

  grade String

  questions PlacementQuestion[]

}



model PlacementQuestion {

  id String @id @default(uuid())


  question String

  optionA String

  optionB String

  optionC String

  optionD String


  correctAnswer String


  skill String


  testId String


  test PlacementTest @relation(
    fields:[testId],
    references:[id]
  )

}



model PlacementResult {

 id String @id @default(uuid())


 studentId String


 score Int


 level String


 createdAt DateTime @default(now())


 student Student @relation(
 fields:[studentId],
 references:[id]
 )

}
}model LearningPath {

  id String @id @default(uuid())

  title String

  description String

  level String

  missions Mission[]

}


model Mission {

  id String @id @default(uuid())

  title String

  description String

  order Int


  pathId String


  path LearningPath @relation(
    fields:[pathId],
    references:[id]
  )

}model World {

  id String @id @default(uuid())

  name String

  description String

  image String?


  characters Character[]

  missions Mission[]

}



model Character {

  id String @id @default(uuid())


  name String

  role String

  description String


  worldId String


  world World @relation(
    fields:[worldId],
    references:[id]
  )

}



model Reward {

  id String @id @default(uuid())


  title String

  type String


  points Int


  missionId String


  mission Mission @relation(
    fields:[missionId],
    references:[id]
  )

}model Mission {

  id String @id @default(uuid())


  title String


  description String


  order Int



  pathId String


  path LearningPath @relation(
    fields:[pathId],
    references:[id]
  )


  worldId String?


  world World? @relation(
    fields:[worldId],
    references:[id]
  )


  rewards Reward[]

